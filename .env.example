# Firebase web config (public by design — safe to expose in the client bundle).
# Copy this file to .env.local and fill in real values from:
#   Firebase console -> Project settings -> Your apps -> Web app
# .env.local is gitignored; this .env.example is committed as the template.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=twoagreeapp.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://twoagreeapp-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=twoagreeapp
VITE_FIREBASE_STORAGE_BUCKET=twoagreeapp.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# In dev (npm run dev), the app talks to the Firebase Emulator Suite.
# Set to false to develop against LIVE Firebase data. Ignored in prod builds.
VITE_USE_EMULATORS=true

# Feature flag: reveal the Path tab. Leave unset/false to ship the Path dark.
# Before flipping this on in production, deploy the generatePath Cloud Function
# (firebase deploy --only functions) — the Path is broken without it.
VITE_PATH_ENABLED=false
